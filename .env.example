## Copy this file to .env.local and fill in real values.
## .env.local is gitignored and will never be committed.

# Project Settings -> API in your Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Secret. Server-side only, never exposed to the browser. Never commit this.
SUPABASE_SERVICE_ROLE_KEY=

# Opt-in switch for the "sign in as <role>" dev panel on the login page.
# Requires SUPABASE_SERVICE_ROLE_KEY as well, and is force-disabled on
# Vercel production deployments regardless of this value. Leave unset
# (or anything other than "true") to keep dev login off.
ALLOW_DEV_LOGIN=
