## Copy this file to .env.local and fill in real values.
## .env.local is gitignored and will never be committed.

# Project Settings -> API in your Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Secret. Server-side only, never exposed to the browser. Never commit this.
SUPABASE_SERVICE_ROLE_KEY=

# Opt-in switch for the "sign in as <role>" dev panel on the login page.
# Requires SUPABASE_SERVICE_ROLE_KEY as well, and is force-disabled on
# Vercel production deployments regardless of this value. Leave unset
# (or anything other than "true") to keep dev login off.
ALLOW_DEV_LOGIN=

# Transactional email (invites, invoice notifications). Optional: with
# either unset, all email sends are silent no-ops. Get an API key at
# https://resend.com; EMAIL_FROM must be a sender the key may use,
# e.g. "Asociatia <noreply@yourdomain.md>".
RESEND_API_KEY=
EMAIL_FROM=

# Absolute base URL used for links inside emails (no trailing slash),
# e.g. https://condominium-six.vercel.app. Optional: without it,
# emails omit the link.
APP_BASE_URL=

# Error monitoring (Sentry). Optional: with NEXT_PUBLIC_SENTRY_DSN
# unset, Sentry stays uninitialized and every capture is a no-op. A
# DSN is public by design (it identifies the ingest endpoint, it is
# not a secret), hence the NEXT_PUBLIC_ prefix. Create a project at
# https://sentry.io -> Project Settings -> Client Keys (DSN).
NEXT_PUBLIC_SENTRY_DSN=
# Optional label for the environment shown in Sentry (defaults to
# VERCEL_ENV, e.g. "production"/"preview").
NEXT_PUBLIC_SENTRY_ENVIRONMENT=
